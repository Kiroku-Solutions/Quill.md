{
	"name": "nomad-md",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/add-sri.mjs && node scripts/check-csp.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:i18n": "node scripts/check-i18n.mjs",
		"check:csp": "node scripts/check-csp.mjs",
		"lint": "prettier --check . && eslint . && node scripts/check-i18n.mjs && node scripts/check-csp.mjs",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "vitest --run",
		"coverage": "vitest --run --coverage",
		"sri": "node scripts/add-sri.mjs"
	},
	"engines": {
		"node": ">=20"
	},
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.0",
			"js-yaml": "^4.2.0"
		}
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/js-yaml": "^4.0.9",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.9",
		"axe-core": "^4.12.1",
		"daisyui": "^5.0.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-dnd-action": "^0.9",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@isomorphic-git/lightning-fs": "^4.6.2",
		"@lucide/svelte": "^1.21.0",
		"dompurify": "^3.4.11",
		"isomorphic-git": "^1.38.5",
		"js-yaml": "^4.2.0",
		"marked": "^18.0.5"
	}
}
